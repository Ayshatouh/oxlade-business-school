# ==========================================
# Oxlade Business School - Environment variables
# ==========================================

# 1. Contact & Branding Details
# Used dynamically across the site (Footer, Header, FAQ, Contact Pages)
NEXT_PUBLIC_BUSINESS_NAME="Oxlade Business School"
NEXT_PUBLIC_BUSINESS_PHONE="+44 (0)20 7123 4567"
NEXT_PUBLIC_BUSINESS_EMAIL="info@oxladebusinessschool.com"
NEXT_PUBLIC_BUSINESS_ADDRESS="London, United Kingdom"

# 2. SEO & Site Meta Information
NEXT_PUBLIC_SITE_URL="https://www.oxladebusinessschool.com"
NEXT_PUBLIC_SITE_TITLE="Oxlade Business School | Corporate Training Courses"
NEXT_PUBLIC_SITE_DESCRIPTION="Over 30 years of delivering premium corporate training. Explore 500+ intensive courses across leadership, finance, digital and more."

# 3. Third-party Integrations
# Web3Forms access key for course enquiries/contact page routing
NEXT_PUBLIC_W3FORMS_ACCESS_KEY="your_w3forms_access_key_here"

# Google Analytics Measurement ID
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# 4. Headless CMS / API Integration (Optional)
# If set, the site will fetch Courses, Dates, and Blogs over network instead of local static JSON
# If blank, the site silently falls back to local data files mapping.
# NEXT_PUBLIC_CONTENT_BASE_URL="https://api.oxladebusinessschool.com"
